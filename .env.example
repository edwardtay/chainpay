# Seed phrase (24 words recommended)
SEED_PHRASE=your twenty four word seed phrase here

# Network mode: "mainnet" (default) or "testnet"
# Set to "testnet" to enable Sepolia and use test USDT
NETWORK_MODE=mainnet

# RPC Providers (mainnet)
ETH_RPC=https://eth.drpc.org
POLYGON_RPC=https://polygon-rpc.com
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc

# RPC Providers (testnet — used when NETWORK_MODE=testnet)
SEPOLIA_RPC=https://sepolia.drpc.org

# TON
TON_RPC=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=

# Tron
TRON_RPC=https://api.trongrid.io

# Solana
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Server
PORT=3000

# Anthropic Claude API Key (for AI reasoning; works offline without it)
ANTHROPIC_API_KEY=

# API authentication for wallet-moving endpoints (required in mainnet mode)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_API_KEY=

# ERC-4337 Gasless Transactions (optional)
BUNDLER_URL=
PAYMASTER_URL=
PAYMASTER_ADDRESS=
SPONSORED=false
SPONSORSHIP_POLICY_ID=

# WDK Indexer API Key (optional)
WDK_API_KEY=
